set -uo pipefail

XCB_VERSION="0.1.2"
XCB_INSTALL_URL="https://raw.githubusercontent.com/bentford/xcb/main/install.sh"
XCB_VERSION_URL="https://raw.githubusercontent.com/bentford/xcb/main/VERSION"
