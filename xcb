            exit 1
        fi
        echo -e "${GREEN}Clean succeeded${NC}"
        echo ""
    fi

    TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    BUILD_LOG="/tmp/xcodebuild-${SCHEME}-${TIMESTAMP}.log"

    xcodebuild build \
        $QUIET_FLAG \
        -workspace "$WORKSPACE" \
        -scheme "$SCHEME" \
        -destination "$DESTINATION" \
        2>&1 | tee "$BUILD_LOG" | xcbeautify
    BUILD_STATUS=${PIPESTATUS[0]}

    if [[ $BUILD_STATUS -ne 0 ]]; then
        show_error_summary "$BUILD_LOG"
        echo ""
        echo -e "${RED}Build failed (exit code: $BUILD_STATUS)${NC}"
        echo -e "${CYAN}Build log:${NC} $BUILD_LOG"
        play_sound $BUILD_STATUS
        exit $BUILD_STATUS
    fi
    show_error_summary "$BUILD_LOG"
    rm -f "$BUILD_LOG"
    if [[ "$QUIET" == true ]]; then
        echo -e "${GREEN}Build succeeded${NC}"
    fi
    play_sound 0
    exit 0
fi

# Build-run action - build and run app in simulator
if [[ "$ACTION" == "build-run" ]]; then
    echo "🚀 Building and running: $SCHEME"
    echo "   Workspace: $WORKSPACE"
    show_destination
    if [[ "$CLEAN" == true ]]; then
        echo "   Clean: yes"
    fi
    echo ""

    if [[ "$DRY_RUN" == true ]]; then
        if [[ "$CLEAN" == true ]]; then
            echo -e "${YELLOW}xcodebuild clean \\${NC}"
            echo -e "${YELLOW}    -workspace \"$WORKSPACE\" \\${NC}"
            echo -e "${YELLOW}    -scheme \"$SCHEME\" \\${NC}"
            echo -e "${YELLOW}    -destination \"$DESTINATION\"${NC}"
            echo ""
        fi
        echo -e "${YELLOW}xcodebuild build \\${NC}"
        if [[ "$QUIET" == true ]]; then
            echo -e "${YELLOW}    -quiet \\${NC}"
        fi
        echo -e "${YELLOW}    -workspace \"$WORKSPACE\" \\${NC}"
        echo -e "${YELLOW}    -scheme \"$SCHEME\" \\${NC}"
        echo -e "${YELLOW}    -destination \"$DESTINATION\" \\${NC}"
        echo -e "${YELLOW}    2>&1 | xcbeautify${NC}"
        echo ""
        if [[ "$DESTINATION_TYPE" == "device" ]]; then
            echo -e "${YELLOW}# Then: install and launch on device${NC}"
            echo -e "${YELLOW}xcrun devicectl device install app --device \"$DEVICE_ID\" <app-path>${NC}"
            echo -e "${YELLOW}xcrun devicectl device process launch --device \"$DEVICE_ID\" <bundle-id>${NC}"
        else
            echo -e "${YELLOW}# Then: boot simulator, install app, launch app${NC}"
        fi
        exit 0
    fi

    require_xcbeautify

    if [[ "$CLEAN" == true ]]; then
        echo -e "${BLUE}Cleaning...${NC}"
        xcodebuild clean \
            -workspace "$WORKSPACE" \
            -scheme "$SCHEME" \
            -destination "$DESTINATION" \
            2>&1 | tail -1
        if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
            echo -e "${RED}Clean failed${NC}"
            play_sound 1
            exit 1
        fi
        echo -e "${GREEN}Clean succeeded${NC}"
        echo ""
    fi

    TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    BUILD_LOG="/tmp/xcodebuild-${SCHEME}-${TIMESTAMP}.log"

    xcodebuild build \
        $QUIET_FLAG \
        -workspace "$WORKSPACE" \
        -scheme "$SCHEME" \
        -destination "$DESTINATION" \
        2>&1 | tee "$BUILD_LOG" | xcbeautify
    BUILD_STATUS=${PIPESTATUS[0]}

    if [[ $BUILD_STATUS -ne 0 ]]; then
        show_error_summary "$BUILD_LOG"
        echo ""
        echo -e "${RED}❌ Build failed (exit code: $BUILD_STATUS)${NC}"
        echo ""
        echo -e "${CYAN}📁 Build log:${NC} $BUILD_LOG"
        play_sound $BUILD_STATUS
        exit $BUILD_STATUS
    fi
    show_error_summary "$BUILD_LOG"
    rm -f "$BUILD_LOG"
    if [[ "$QUIET" == true ]]; then
        echo -e "${GREEN}Build succeeded${NC}"
    fi

    # Fetch all build settings in one call to avoid multiple slow xcodebuild invocations
    # -showBuildSettings emits one block per target in the scheme; grep for the .app product
    # specifically so multi-target schemes (e.g. app + embedded framework) resolve correctly.
    BUILD_SETTINGS=$(xcodebuild -workspace "$WORKSPACE" -scheme "$SCHEME" -destination "$DESTINATION" -showBuildSettings 2>/dev/null)

    # BUNDLE_ID is read from the resolved app's Info.plist rather than from
    # build settings, to avoid picking up a sibling target's bundle id.
    IFS=$'\t' read -r APP_NAME APP_PATH < <(echo "$BUILD_SETTINGS" | parse_app_build_settings)
    BUNDLE_ID=""
    if [[ -n "$APP_PATH" && -n "$APP_NAME" ]]; then
        BUNDLE_ID=$(defaults read "$APP_PATH/$APP_NAME/Info.plist" CFBundleIdentifier 2>/dev/null)
    fi

    if [[ -z "$APP_PATH" || -z "$APP_NAME" ]]; then
        echo -e "${YELLOW}⚠ Could not determine app path. Build succeeded but cannot auto-launch.${NC}"
        echo -e "${YELLOW}  Make sure your scheme includes a runnable .app target.${NC}"
        play_sound 0
        exit 0
    fi

    FULL_APP_PATH="$APP_PATH/$APP_NAME"

    if [[ "$DESTINATION_TYPE" == "device" ]]; then
        launch_on_device "$FULL_APP_PATH" "$BUNDLE_ID" "$DEVICE_ID"
    else
        launch_on_simulator "$FULL_APP_PATH" "$BUNDLE_ID" "$SIMULATOR_ID"
    fi

    play_sound 0
    exit 0
fi

# Run action - launch last built app (no build)
if [[ "$ACTION" == "run" ]]; then
