        XCRESULT_PATH=$(find_most_recent_xcresult "${SCHEME:-}")
        if [[ -z "$XCRESULT_PATH" ]]; then
            echo -e "${RED}Error: No .xcresult found in current directory or DerivedData${NC}"
            echo -e "${YELLOW}Tip: Run tests with coverage first${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Found: $(basename "$XCRESULT_PATH")${NC}"
    fi
elif [[ -z "${SCHEME:-}" ]]; then
    echo -e "${RED}Error: Scheme is required${NC}"
    echo -e "${YELLOW}Tip: Run '$0 select scheme' or pass -s <scheme>${NC}"
    exit 1
fi

if [[ "$SKIP_BUILD" != true ]]; then
    # Validate required settings
    if [[ -z "$WORKSPACE" ]]; then
        echo -e "${RED}Error: Workspace is not set${NC}"
        echo -e "${YELLOW}Tip: Run '$0 select workspace' or pass -w <workspace>${NC}"
        exit 1
    fi

    # Default to simulator for backward compatibility
    if [[ -z "$DESTINATION_TYPE" ]]; then
        DESTINATION_TYPE="simulator"
    fi

    # Build destination string based on destination type
    if [[ "$DESTINATION_TYPE" == "simulator" ]]; then
        if [[ -z "$SIMULATOR_ID" ]]; then
            echo -e "${RED}Error: Simulator is not set${NC}"
            echo -e "${YELLOW}Tip: Run '$0 select simulator' or pass --simulator-id <uuid>${NC}"
            exit 1
        fi
        DESTINATION="platform=iOS Simulator,id=${SIMULATOR_ID}"
    elif [[ "$DESTINATION_TYPE" == "device" ]]; then
        if [[ -z "$DEVICE_ID" ]]; then
            echo -e "${RED}Error: Device identifier is not set${NC}"
            echo -e "${YELLOW}Tip: Run '$0 select device' or pass --device-id <uuid>${NC}"
            exit 1
        fi
        DESTINATION="platform=iOS,id=${DEVICE_ID}"
    else
        echo -e "${RED}Error: Unknown destination type '$DESTINATION_TYPE'${NC}"
        echo -e "${YELLOW}Tip: Use 'simulator' or 'device'${NC}"
        exit 1
    fi
fi

play_sound() {
    if [[ "$AUDIBLE" != true ]]; then
        return
    fi
    if ! command -v afplay &>/dev/null; then
        return
    fi
    local sound_file
    if [[ "$1" -eq 0 ]]; then
        sound_file="/System/Library/Sounds/Glass.aiff"
    else
        sound_file="/System/Library/Sounds/Basso.aiff"
    fi
    afplay "$sound_file" &>/dev/null &
}

# Print the destination line for status output
show_destination() {
    if [[ "$DESTINATION_TYPE" == "device" ]]; then
        echo "   Destination: ${DEVICE_NAME:-$DEVICE_ID} device"
    else
        local sim_label="${SIMULATOR_NAME:-$SIMULATOR_ID}"
        if [[ -n "${SIMULATOR_OS:-}" ]]; then
            sim_label="$sim_label (iOS $SIMULATOR_OS)"
        fi
        echo "   Destination: $sim_label simulator"
    fi
}

# Install and launch an app on a physical device
# Usage: launch_on_device <app_path> <bundle_id> <device_id>
launch_on_device() {
    local app_path="$1"
    local bundle_id="$2"
    local device_id="$3"

    echo "📲 Installing app on device..."
    xcrun devicectl device install app --device "$device_id" "$app_path"

    echo "🚀 Launching app on device..."
    if [[ -n "$bundle_id" ]]; then
        xcrun devicectl device process launch --device "$device_id" "$bundle_id"
        echo ""
        echo -e "${GREEN}✅ App launched: $bundle_id${NC}"
    else
        echo -e "${YELLOW}⚠ App installed but could not determine bundle ID to launch${NC}"
    fi
}

# Boot simulator, install, and launch an app
# Usage: launch_on_simulator <app_path> <bundle_id> <simulator_id>
launch_on_simulator() {
    local app_path="$1"
    local bundle_id="$2"
    local simulator_id="$3"
    echo "📱 Launching simulator..."
    xcrun simctl boot "$simulator_id" 2>/dev/null || true
    open -a Simulator

    # Wait for SpringBoard to be fully ready before installing/launching.
    # simctl boot returns before the simulator is interactive — launching too
    # early causes FBSOpenApplicationServiceErrorDomain/denied by service delegate.
    echo "⏳ Waiting for simulator to be ready..."
    xcrun simctl bootstatus "$simulator_id" -b 2>/dev/null || true

    echo "📲 Installing app..."
    xcrun simctl install "$simulator_id" "$app_path"

    echo "🚀 Launching app..."
    if [[ -n "$bundle_id" ]]; then
        xcrun simctl launch "$simulator_id" "$bundle_id"
        echo ""
        echo -e "${GREEN}✅ App launched: $bundle_id${NC}"
    else
        echo -e "${YELLOW}⚠ App installed but could not determine bundle ID to launch${NC}"
    fi
}

# Clean action - clean derived data for scheme
if [[ "$ACTION" == "clean" ]]; then
    echo "Cleaning: $SCHEME"
    echo "   Workspace: $WORKSPACE"
    show_destination
    echo ""

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${YELLOW}xcodebuild clean \\${NC}"
        echo -e "${YELLOW}    -workspace \"$WORKSPACE\" \\${NC}"
        echo -e "${YELLOW}    -scheme \"$SCHEME\" \\${NC}"
        echo -e "${YELLOW}    -destination \"$DESTINATION\"${NC}"
        exit 0
    fi

    xcodebuild clean \
        -workspace "$WORKSPACE" \
        -scheme "$SCHEME" \
        -destination "$DESTINATION" \
        2>&1 | tail -1
    CLEAN_STATUS=${PIPESTATUS[0]}

    if [[ $CLEAN_STATUS -ne 0 ]]; then
        echo -e "${RED}Clean failed (exit code: $CLEAN_STATUS)${NC}"
        play_sound $CLEAN_STATUS
        exit $CLEAN_STATUS
    fi
    echo -e "${GREEN}Clean succeeded${NC}"
    play_sound 0
    exit 0
fi

# Build action - build only
if [[ "$ACTION" == "build" ]]; then
    echo "Building: $SCHEME"
    echo "   Workspace: $WORKSPACE"
    show_destination
    if [[ "$CLEAN" == true ]]; then
        echo "   Clean: yes"
    fi
    echo ""

    if [[ "$DRY_RUN" == true ]]; then
        if [[ "$CLEAN" == true ]]; then
            echo -e "${YELLOW}xcodebuild clean \\${NC}"
            echo -e "${YELLOW}    -workspace \"$WORKSPACE\" \\${NC}"
            echo -e "${YELLOW}    -scheme \"$SCHEME\" \\${NC}"
            echo -e "${YELLOW}    -destination \"$DESTINATION\"${NC}"
            echo ""
        fi
        echo -e "${YELLOW}xcodebuild build \\${NC}"
        if [[ "$QUIET" == true ]]; then
            echo -e "${YELLOW}    -quiet \\${NC}"
        fi
        echo -e "${YELLOW}    -workspace \"$WORKSPACE\" \\${NC}"
        echo -e "${YELLOW}    -scheme \"$SCHEME\" \\${NC}"
        echo -e "${YELLOW}    -destination \"$DESTINATION\" \\${NC}"
        echo -e "${YELLOW}    2>&1 | xcbeautify${NC}"
        exit 0
    fi

    require_xcbeautify

    if [[ "$CLEAN" == true ]]; then
        echo -e "${BLUE}Cleaning...${NC}"
        xcodebuild clean \
            -workspace "$WORKSPACE" \
            -scheme "$SCHEME" \
            -destination "$DESTINATION" \
            2>&1 | tail -1
        if [[ ${PIPESTATUS[0]} -ne 0 ]]; then
            echo -e "${RED}Clean failed${NC}"
