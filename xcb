# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

require_xcbeautify() {
    if ! command -v xcbeautify &>/dev/null; then
        echo -e "${RED}Error: xcbeautify is not installed${NC}"
        echo -e "${YELLOW}Install with: brew install xcbeautify${NC}"
        exit 1
    fi
}

# Show a post-build summary of warnings, errors, and (optionally) test failures.
# Pass "true" as $2 to include test results in the summary.
show_error_summary() {
    local build_log="$1"
    local include_tests="${2:-false}"
    local summary
    if [[ "$include_tests" == true ]]; then
        # Extract failure lines from the raw log and format with xcbeautify.
        # ✘ = Swift Testing failures; ": error: -[" = XCTest assertion failures
        summary=$(grep -E '✘ |: error: -\[' "$build_log" | head -50 | xcbeautify --disable-logging)
    else
        summary=$(xcbeautify --quiet < "$build_log")
    fi
    summary=$(echo "$summary" | sed '/^[[:space:]]*$/d')
    if [[ -n "$summary" ]]; then
        echo ""
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo "$summary"
        echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    fi
}

# Reads `xcodebuild -showBuildSettings` output on stdin; prints
# "<FULL_PRODUCT_NAME>\t<BUILT_PRODUCTS_DIR>" for the first target whose
# product name ends in .app. Empty output if no .app target found.
# Each target block contains BUILT_PRODUCTS_DIR before FULL_PRODUCT_NAME, so
# we remember the most recent dir and emit on the first matching .app name.
parse_app_build_settings() {
    awk '
        match($0, /[[:space:]]BUILT_PRODUCTS_DIR[[:space:]]*=[[:space:]]*/) {
            last_dir = substr($0, RSTART + RLENGTH)
        }
        match($0, /[[:space:]]FULL_PRODUCT_NAME[[:space:]]*=[[:space:]]*/) {
            name = substr($0, RSTART + RLENGTH)
            if (name ~ /\.app$/) { print name "\t" last_dir; exit }
        }
    '
}

# Hidden subcommand for unit tests: read showBuildSettings output on stdin,
# print the parsed app name + path (tab-delimited). Not documented in usage.
if [[ "${1:-}" == "--parse-build-settings" ]]; then
    parse_app_build_settings
    exit 0
fi

if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
    echo "xcb $XCB_VERSION"
    exit 0
fi

if [[ "${1:-}" == "--update" ]]; then
    update_dry_run=false
    if [[ "${2:-}" == "--dry-run" ]]; then
        update_dry_run=true
    fi
    if ! command -v curl &>/dev/null; then
        echo "Error: curl is required to update xcb" >&2
        exit 1
    fi

    # install.sh writes to $HOME/bin/xcb. If the running xcb lives elsewhere
    # (Homebrew, /usr/local/bin, custom path), the install would create a second
    # copy rather than upgrade the one in use.
    running_path="$(cd "$(dirname -- "$0")" 2>/dev/null && pwd -P)/$(basename -- "$0")"
    expected_dir="$HOME/bin"
    if [[ -d "$expected_dir" ]]; then
        expected_dir="$(cd "$expected_dir" && pwd -P)"
    fi
    expected_path="$expected_dir/xcb"
    path_mismatch=false
    if [[ "$running_path" != "$expected_path" ]]; then
        path_mismatch=true
    fi

    echo "Checking for updates..."
    remote_version=$(curl -fsSL "$XCB_VERSION_URL" 2>/dev/null | tr -d '[:space:]')
    if [[ -z "$remote_version" ]]; then
        echo "Error: could not fetch remote version from $XCB_VERSION_URL" >&2
        exit 1
    fi
    if [[ "$remote_version" == "$XCB_VERSION" ]]; then
        echo "xcb is up to date (v$XCB_VERSION)"
        exit 0
    fi
    if [[ "$path_mismatch" == true ]]; then
        echo ""
        echo "Warning: running xcb is at $running_path"
        echo "         but the installer writes to $expected_path"
        echo "         Updating will create a second copy at $expected_path"
        echo "         instead of upgrading the one currently on your PATH."
        echo ""
    fi
    if [[ "$update_dry_run" == true ]]; then
        echo "Would update xcb $XCB_VERSION -> $remote_version"
        echo "Would run: curl -fsSL $XCB_INSTALL_URL | bash"
        echo "Changelog: $XCB_CHANGELOG_URL"
        exit 0
    fi
    echo "Updating xcb $XCB_VERSION -> $remote_version..."
    if ! curl -fsSL "$XCB_INSTALL_URL" | bash; then
        echo "Error: update failed" >&2
        exit 1
    fi
    echo "xcb updated to v$remote_version"
    echo "Changelog: $XCB_CHANGELOG_URL"
    exit 0
fi

# Default values (set via 'select' commands or CLI flags; saved in .xcbrc)
WORKSPACE=""
SIMULATOR_NAME=""     # Human-readable simulator name (for display only)
SIMULATOR_ID=""       # simctl UUID for simulator
SIMULATOR_OS=""       # iOS version for simulator (for display only)
SCHEME=""
DESTINATION_TYPE=""   # "simulator" or "device"
DEVICE_ID=""          # CoreDevice identifier (UUID) for physical devices
DEVICE_NAME=""        # Human-readable device name (for display only)
ACTION=""
SUB_ACTION=""
SKIP_BUILD=false
DETAILED=false
ONLY_TEST=""
FORCE=false
FILTER=""
FILTER_SCHEME=false
DRY_RUN=false
CLEAN=false
AUDIBLE=false
QUIET=false


# Load saved defaults from .xcbrc
XCB_CONFIG=".xcbrc"
if [[ -f "$XCB_CONFIG" ]]; then
    source "$XCB_CONFIG"
    # Backward compatibility: migrate IPHONE_NAME from old .xcbrc files
    if [[ -n "${IPHONE_NAME:-}" && -z "$SIMULATOR_NAME" ]]; then
        SIMULATOR_NAME="$IPHONE_NAME"
    fi
    # Detect old config that can't be auto-migrated (name/version but no UUID)
    if [[ -n "${IPHONE_NAME:-}${OS_VERSION:-}" && -z "$SIMULATOR_ID" ]]; then
        echo -e "${YELLOW}Note: Your .xcbrc uses the old IPHONE_NAME/OS_VERSION format.${NC}"
        echo -e "${YELLOW}Run 'xcb select simulator' to update your config.${NC}"
        echo ""
    fi
fi

# Write or update a KEY="VALUE" pair in the config file, or remove it if value is empty.
# Usage: set_config KEY VALUE
set_config() {
    local key="$1" value="$2"
    if [[ -z "$value" ]]; then
        # Remove the key
        if [[ -f "$XCB_CONFIG" ]] && grep -q "^${key}=" "$XCB_CONFIG"; then
            grep -v "^${key}=" "$XCB_CONFIG" > "$XCB_CONFIG.tmp" || true
            mv "$XCB_CONFIG.tmp" "$XCB_CONFIG"
        fi
    else
        # Delete existing line (if any) then append — avoids sed metachar issues in value
        if [[ -f "$XCB_CONFIG" ]] && grep -q "^${key}=" "$XCB_CONFIG"; then
            grep -v "^${key}=" "$XCB_CONFIG" > "$XCB_CONFIG.tmp" || true
            mv "$XCB_CONFIG.tmp" "$XCB_CONFIG"
        fi
        echo "${key}=\"$value\"" >> "$XCB_CONFIG"
    fi
}

